# Optional — only needed for local preview (`bundle install && bundle exec jekyll serve`).
# GitHub Pages builds the site automatically on push; you never have to run this.
source 'https://rubygems.org'

gem 'github-pages', group: :jekyll_plugins

# Windows niceties
